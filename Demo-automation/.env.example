# Fabric Demo Automation - Environment Variables Template
# ======================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be committed.

# Required: Your Microsoft Fabric workspace ID (GUID)
# Find this in the Fabric portal URL: https://app.fabric.microsoft.com/groups/<workspace-id>/...
FABRIC_WORKSPACE_ID=

# Optional: Azure AD tenant ID
# Required for service principal authentication or multi-tenant scenarios
# AZURE_TENANT_ID=

# Optional: Service Principal credentials (for non-interactive/CI scenarios)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# =============================================================================
# Environment Selection (Optional)
# =============================================================================
# Each environment has its own API and OneLake endpoints.
# The workspace ID determines which environment's resources you access.
# You typically don't need to set these - just use the correct workspace ID.
#
# Default endpoints:
#   API:     api.fabric.microsoft.com
#   OneLake: onelake.dfs.fabric.microsoft.com

# Default API endpoints (no need to change):
# FABRIC_API_BASE=https://api.fabric.microsoft.com
# FABRIC_API_SCOPE=https://api.fabric.microsoft.com/.default
